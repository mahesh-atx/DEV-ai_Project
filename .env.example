# Required: Get your API key from https://build.nvidia.com
# You can also set this interactively when you first run `devai`
NVIDIA_API_KEY=your_nvidia_api_key_here

# Optional: Override the default NVIDIA NIM base URL
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Optional: OpenRouter key for OpenRouter-hosted models
# 

# Optional: Override the default OpenRouter base URL
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional: OpenRouter ranking headers
# OPENROUTER_HTTP_REFERER=https://your-app.example.com
# OPENROUTER_APP_NAME=RootX CLI
